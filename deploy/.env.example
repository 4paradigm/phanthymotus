# 腾讯云镜像仓库配置
# 复制此文件为 .env，填入真实值（.env 已被 .gitignore 排除，不会提交到仓库）

# 镜像仓库地址，例如腾讯云 TCR
REGISTRY=ccr.ccs.tencentyun.com

# 仓库用户名
REGISTRY_USER=your-username

# 仓库密码或访问 Token
REGISTRY_PASSWORD=your-password

# 镜像命名空间，例如：your-namespace
IMAGE_NAMESPACE=your-namespace

# resource-center 镜像注册（可选）
# 默认同步到 https://motus.phanthy.com，如需指向其他实例可覆盖
# RESOURCE_CENTER_URL=https://motus.phanthy.com
# 在 https://motus.phanthy.com/keys 注册账号后生成，格式 rc_xxxx
# 若未设置，build_core.sh 不会询问同步步骤
# RESOURCE_CENTER_API_KEY=rc_your-api-key-here
